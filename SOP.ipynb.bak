    "PUBLIC_FRED_API_KEY = \"99b6b648410a405f7a66d8117889ea0e\"\n",
    "FRED_API_KEY = os.getenv(\"FRED_API_KEY\", PUBLIC_FRED_API_KEY)\n",
    "\n",
    "USE_FRED_EXTENSION = True\n",
