   "source": [
    "# Define eval_base used by downstream forecast-robustness code\n",
    "# This is the monthly evaluation panel used by robustness checks\n",
    "eval_base = df[df[\"forecast_target_date\"] >= pd.Timestamp(FORECAST_START)].copy()\n",
    "print(f\"eval_base defined: {len(eval_base)} rows from {eval_base['forecast_target_date'].min().date()} to {eval_base['forecast_target_date'].max().date()}\")"
   ]
  },
